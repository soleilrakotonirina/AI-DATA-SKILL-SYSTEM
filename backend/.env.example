
# =============================================================================
# .env.example — Configuration AI DATA SKILL SYSTEM 2026
# Stack : Next.js + FastAPI + Pydantic + Directus + Gemini
# =============================================================================
#
# UTILISATION :
#   1. Copier ce fichier : cp .env.example .env
#   2. Renseigner les valeurs ci-dessous
#   3. NE JAMAIS partager le fichier .env (clés secrètes)
#
# Obtenir une clé Gemini gratuite : https://aistudio.google.com → Get API Key
# =============================================================================


# =============================================================================
# ── SECTION 1 — Données & Chemins ─────────────────────────────────────────
# =============================================================================


# Dossier contenant vos datasets bruts (jamais modifiés)
DATA_RAW_DIR=./data/raw 

# Dossier de sortie des datasets nettoyés par le ETL Skill
DATA_PROCESSED_DIR=./data/processed 

# Dossier pour les données externes (APIs, benchmarks, référentiels)
DATA_EXTERNAL_DIR=./data/external 

# Dossier pour les résultats de sortie des résultats : graphiques, rapports, exports CSV
OUTPUTS_DIR=./outputs 

# Dossier pour les modèles entraînés
MODELS_DIR=./models 

# =============================================================================
# ── SECTION 2 — SDK Gemini (Orchestrateur IA) ─────────────────────────────
# =============================================================================

# ── Clé principale (obligatoire — tous les Skills en dépendent) ──────────────

GEMINI_API_KEY=AIzaSy...RemplacerParVotreVraieCle

# ── Clés de rotation (optionnelles — recommandées pour éviter les quotas) ─────
# Gemini a une limite de 15 requêtes/minute par clé gratuite.
# Avec 10 clés : jusqu'à 150 requaêtes/minute disponibles.
GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=


# ── Modèle Gemini (ne pas modifier sauf raison spécifique) ───────────────────
GEMINI_MODEL=gemini-2.5-flash

# ── Paramètres de génération ─────────────────────────────────────────────────
# Contrôle la créativité des réponses (0.0 = déterministe, 1.0 = créatif)
# Recommandé 0.2 pour l'orchestration, 0.7 pour les insights narratifs
GEMINI_TEMPERATURE=0.2

# Nombre maximum de tokens générés par réponse
GEMINI_MAX_TOKENS=1000

# Timeout par requête en secondes
GEMINI_TIMEOUT=25


# =============================================================================
# ── SECTION 3 — Directus CMS (Stockage MDX) ───────────────────────────────
# =============================================================================

DIRECTUS_URL=http://localhost:8055

# Token admin à générer dans Directus (voir Phase 0.5)
DIRECTUS_TOKEN=RemplacerParVotreTokenAdminDirectus

# Identifiants admin (utilisés à l'init de Directus)
DIRECTUS_ADMIN_EMAIL=admin@aidataskill.local
DIRECTUS_ADMIN_PASSWORD=ChangerCeMotDePasse123

# =============================================================================
# ── SECTION 4 — FastAPI Backend ───────────────────────────────────────────
# =============================================================================

FASTAPI_PORT=8000
FASTAPI_HOST=127.0.0.1

# Origines CORS autorisées (URL de Next.js)
CORS_ORIGINS=http://localhost:3000


# =============================================================================
# ── SECTION 5 — ETL Skill ─────────────────────────────────────────────────
# =============================================================================


# Seuil de nullité au-delà duquel une colonne est supprimée (0.0 à 1.0)
# Ex : 0.5 = suppression si plus de 50% de valeurs manquantes
ETL_NULL_THRESHOLD=0.5

# Stratégie par défaut pour les valeurs manquantes numériques : mean | median
ETL_NUMERIC_IMPUTATION=median

# Stratégie par défaut pour les valeurs manquantes catégorielles : mode | unknown
ETL_CATEGORICAL_IMPUTATION=mode

# Multiplicateur IQR pour la détection des outliers (standard = 1.5)
ETL_IQR_MULTIPLIER=1.5

# Stratégie de traitement des outliers : drop | cap | flag
ETL_OUTLIER_STRATEGY=cap


# =============================================================================
# ── SECTION 6 — Modeling Skill (Machine Learning) ────────────────────────────
# =============================================================================


# Proportion du dataset réservée au test (0.0 à 1.0)
ML_TEST_SIZE=0.2

# Nombre de folds pour la cross-validation
ML_CV_FOLDS=5

# Graine aléatoire pour la reproductibilité des résultats
ML_RANDOM_STATE=42

# Nombre de jobs parallèles pour GridSearchCV (-1 = tous les cœurs disponibles)
ML_N_JOBS=-1

# Activer le tuning automatique des hyperparamètres : true | false
ML_AUTO_TUNING=true


# =============================================================================
# ── SECTION 7 — Environnement ─────────────────────────────────────────────
# =============================================================================


# Environnement d'exécution : development | production
APP_ENV=development

# Niveau de logs : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Activer le mode debug Streamlit (affichage des erreurs détaillées)
DEBUG=false